{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/health/fireant",
      "destination": "/api/health-fireant"
    },
    {
      "source": "/api/news",
      "destination": "/api/news"
    },
    {
      "source": "/api/news/:id",
      "destination": "/api/detail?id=:id"
    },
    {
      "source": "/api/ai/:path*",
      "destination": "/api/ai?path=:path*"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
