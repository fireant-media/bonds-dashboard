{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/health/fireant",
      "destination": "/api/health-fireant.ts"
    },
    {
      "source": "/api/news",
      "destination": "/api/news.ts"
    },
    {
      "source": "/api/news/:id",
      "destination": "/api/detail.ts?id=:id"
    },
    {
      "source": "/api/fireant/:path*",
      "destination": "/api/proxy.ts?path=:path*"
    },
    {
      "source": "/api/ai/:path*",
      "destination": "/api/ai.ts?path=:path*"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth.ts?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
