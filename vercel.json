{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/health/fireant",
      "destination": "/api/health-fireant"
    },
    {
      "source": "/api/fireant/bonds/filter",
      "destination": "/api/fireant/bonds/filter"
    },
    {
      "source": "/api/fireant/:path*",
      "destination": "/api/proxy?path=:path*"
    },
    {
      "source": "/api/fa/:path*",
      "destination": "/api/proxy?path=:path*"
    },
    {
      "source": "/api/news/:id",
      "destination": "/api/news?id=:id"
    },
    {
      "source": "/api/news",
      "destination": "/api/news"
    },
    {
      "source": "/api/page-data/:view",
      "destination": "/api/page-data?view=:view"
    },
    {
      "source": "/api/page-data",
      "destination": "/api/page-data"
    },
    {
      "source": "/api/ai/:path*",
      "destination": "/api/ai?path=:path*"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login"
    },
    {
      "source": "/api/auth/logout",
      "destination": "/api/auth/logout"
    },
    {
      "source": "/api/auth/session",
      "destination": "/api/auth/session"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
