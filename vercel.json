{
  "version": 2,
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/news",
      "destination": "/api/news.ts"
    },
    {
      "source": "/api/news/:id",
      "destination": "/api/detail.ts?id=:id"
    },
    {
      "source": "/api/fireant/:path*",
      "destination": "/api/proxy.ts?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
